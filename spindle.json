{
  "version": "0.3.5",
  "name": "LumiRealm",
  "identifier": "lumirealm",
  "author": "amousepad",
  "github": "https://github.com/AMousePad/LumiRealm",
  "homepage": "https://github.com/AMousePad/LumiRealm",
  "description": "Bringing RisuRealm into Lumiverse",
  "permissions": [
    "chat_mutation",
    "chats",
